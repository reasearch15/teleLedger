APP_NAME=Telegram Ledger API
APP_ENV=development
APP_DEBUG=false
APP_LOG_LEVEL=INFO
APP_API_PREFIX=/api/v1
APP_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ledger_db
DATABASE_USER=ledger_user
DATABASE_PASSWORD=replace_with_a_secure_password
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

AUTH_SECRET_KEY=replace_with_at_least_32_random_characters
AUTH_COOKIE_NAME=telegram_ledger_session
AUTH_COOKIE_SECURE=false
AUTH_SESSION_MINUTES=480

TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=replace_with_your_api_hash
TELEGRAM_SESSION_NAME=telegram-ledger
# Set exactly one group selector:
# TELEGRAM_GROUP_ID=-1001234567890
TELEGRAM_GROUP_USERNAME=@replace_with_your_group
TELEGRAM_CASHOUT_GROUP_ID=-1001234567890
TELEGRAM_ENABLED=false
TELEGRAM_BACKFILL_LIMIT=500
# Comma-separated completion reactions. Use * or any for legacy "any reaction".
CASHOUT_COMPLETION_REACTIONS=✅,👍
CASHOUT_RECONCILIATION_INTERVAL_SECONDS=20
CASHOUT_RECONCILIATION_BATCH_SIZE=40
